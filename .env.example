# ── Supabase ──────────────────────────────────────────────────────────────────
# Public, safe to expose in frontend — prefixed with VITE_ so Vite includes them
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── App config ────────────────────────────────────────────────────────────────
VITE_APP_URL=https://aiwithrakshith.tech

# ── Google reCAPTCHA ──────────────────────────────────────────────────────────
# Get keys at https://www.google.com/recaptcha/admin
# v3 key (invisible, score-based) — used on all auth forms
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-v3-site-key
# v2 key ("I'm not a robot" checkbox) — shown on login + signup forms
VITE_RECAPTCHA_V2_SITE_KEY=your-recaptcha-v2-site-key

# ── BACKEND-ONLY secrets (Supabase Edge Function env vars, set via dashboard) ─
# These are never read in the frontend. Set them in:
#   Supabase Dashboard → Edge Functions → Manage secrets
# Listed here for documentation only — do NOT put real values here.
#
# RECAPTCHA_SECRET_KEY=your-recaptcha-v3-secret-key (set in Supabase Edge Function secrets)
# RESEND_API_KEY=re_...
# SUPABASE_SERVICE_ROLE_KEY=auto-managed-by-supabase
# APP_URL=https://aiwithrakshith.tech

# ── Optional: error monitoring ────────────────────────────────────────────────
# Set in hosting provider environment, NOT committed here.
# VITE_SENTRY_DSN=https://...@sentry.io/...

# ── Local dev only ────────────────────────────────────────────────────────────
# Set VITE_DEV_MODE=true to enable verbose logging in browser console
VITE_DEV_MODE=false
